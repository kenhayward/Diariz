{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "noUnusedLocals": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true
  },
  "include": ["credentials/**/*", "nodes/**/*"],
  "exclude": ["dist", "dist-test", "node_modules", "test", "scripts"]
}
