# Copy to .env and fill in. Never commit the real .env.

# Postgres
POSTGRES_PASSWORD=diariz

# MinIO (object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio

# JWT signing key — must be at least 32 characters
JWT_KEY=replace-with-a-long-random-secret-at-least-32-chars

# Shared secret the worker uses on the internal callback endpoint
CALLBACK_SECRET=change-me-worker-secret

# Seed user (the Platform Administrator) created on first startup
SEED_EMAIL=admin@example.com
SEED_PASSWORD=ChangeMe123!
SEED_FULL_NAME=Platform Administrator

# Public browser URL, used to build the account-setup link in emails (the web origin, not the API).
APP_PUBLIC_URL=http://localhost:8081

# SMTP for the account-setup email. Leave SMTP_HOST empty to disable email — the grant screen then
# shows the one-time setup link for an admin to share manually.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_STARTTLS=true

# Hugging Face token for pyannote diarization (gated models — accept their terms first)
HF_TOKEN=

# Worker compute (defaults target GPU). For CPU-only: WORKER_DEVICE=cpu, WORKER_COMPUTE_TYPE=int8
WORKER_DEVICE=cuda
WORKER_COMPUTE_TYPE=float16
WHISPER_MODEL=large-v3
# WhisperX transcription batch size. Lower it (e.g. 8 or 4) to reduce peak VRAM on smaller GPUs
# (see src/Diariz.Worker/README.md → GPU and hardware requirements).
BATCH_SIZE=16
# Reject uploaded/recorded audio longer than this many seconds (0 = unlimited). 14400 = 4 h.
MAX_AUDIO_SECONDS=14400

# Uploaded audio files (the "Upload" button). Server validates the actual bytes (magic-byte sniff).
# UPLOAD_MAX_BYTES caps a single file (524288000 = 500 MB). UPLOAD_ALLOW_AAC=false drops M4A/AAC
# (which has active patents) for maximum commercial caution; royalty-free formats are always accepted.
UPLOAD_MAX_BYTES=524288000
UPLOAD_ALLOW_AAC=true

# Speaker identification (enrolled voiceprints). The worker extracts a per-speaker ECAPA
# embedding; the API auto-matches it against the owner's enrolled people within Threshold
# (max cosine distance — conservative default, tune for your audio). Set ENABLE_SPEAKER_EMBEDDINGS=0
# to skip embedding extraction entirely.
ENABLE_SPEAKER_EMBEDDINGS=1
IDENTIFICATION_ENABLED=true
IDENTIFICATION_THRESHOLD=0.4

# LLM summarisation (OpenAI-compatible endpoint). Leave SUMMARY_API_BASE empty to disable the
# Summarise button. Works with OpenAI, a local server (Ollama/LM Studio/vLLM), etc.
#   e.g. SUMMARY_API_BASE=https://api.openai.com/v1  or  http://host.docker.internal:1234/v1
SUMMARY_API_BASE=
SUMMARY_API_KEY=
SUMMARY_MODEL=gpt-4o-mini

# Chat reuses the same per-user LLM endpoint/model/key as summarisation. Only the context-window
# size (tokens) is chat-specific; it drives the context dial and is overridable per-user in Settings.
CHAT_CONTEXT_LENGTH=131072
# Chat tool calling (built-in transcript tools). Off by default — needs a model that supports OpenAI
# tool calling. CHAT_DISABLED_TOOLS is a comma-separated list of tool names off by default server-wide
# (every other registered tool is on). Both are overridable per-user in Settings.
CHAT_TOOLS_ENABLED=false
CHAT_DISABLED_TOOLS=
